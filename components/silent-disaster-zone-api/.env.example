# Central Weather Administration API key
# Get your own key from CWA Open Data platform.
CWA_API_KEY=your_cwa_api_key_here

# Optional runtime setting
ENV=development

# Optional Ollama command advisor
# If Ollama is running locally, the API can generate command suggestions.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b


# Report review API protection.
REPORT_ADMIN_KEY=replace_with_a_long_random_secret

# Used to hash LINE user IDs before storing reports.
REPORTER_HASH_SECRET=replace_with_a_second_long_random_secret

# LINE Messaging API.
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Short-lived API authentication.
AUTH_LOGIN_USERNAME=api-admin
AUTH_LOGIN_PASSWORD_HASH=replace_with_pbkdf2_hash
AUTH_STORAGE_SECRET=replace_with_long_random_secret

# 只有在 Uvicorn 綁定 127.0.0.1 且前面有你信任的 Caddy/Nginx 時才改 true。
AUTH_TRUST_PROXY_HEADERS=false