# Central Weather Administration API key
# Get your own key from CWA Open Data platform.
CWA_API_KEY=your_cwa_api_key_here

# Water Resources Agency OpenAPI endpoint.
# Optional. The MVP can run without WRA if this is not configured.
WRA_API_URL=

# Optional runtime setting
ENV=development

# Optional Ollama command advisor
# If Ollama is running locally, the API can generate command suggestions.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
