{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DisasterReportInput",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "report_id",
      "source",
      "report_type",
      "severity",
      "created_at",
      "lon",
      "lat",
      "description"
    ],
    "properties": {
      "report_id": {
        "type": "string"
      },
      "source": {
        "type": "string",
        "description": "Report source, e.g. Mock, LINE, 119, 1999, WebForm."
      },
      "report_type": {
        "type": "string",
        "description": "Report type, e.g. flood, debris, road_block."
      },
      "severity": {
        "type": "integer",
        "minimum": 1,
        "maximum": 5
      },
      "created_at": {
        "type": "string",
        "format": "date-time"
      },
      "lon": {
        "type": "number"
      },
      "lat": {
        "type": "number"
      },
      "description": {
        "type": "string"
      }
    },
    "additionalProperties": true
  }
}
