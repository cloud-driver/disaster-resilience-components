# Ollama model configuration
# For local development, use localhost.
# Do not commit private IPs, Tailscale IPs, ngrok URLs, API keys, or tokens.

OLLAMA_BASE_URL=http://localhost:11434

# Dispatch model: lightweight model for faster assignment
OLLAMA_MODEL_DISPATCH=llama3:8b

# Debug model: larger model for validation
OLLAMA_MODEL_DEBUG=llama3:latest
